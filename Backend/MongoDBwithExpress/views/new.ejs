<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Chat</title>
</head>
<body>

    <h1> New Chat</h1>
    <form method="post" action="/chats">
        <input type="text" name="from" placeholder="enter senders name">
        <br><br>
        <input type="text" name="to" placeholder="enter receiver name">
        <br><br>
        <textarea cols="25" rows="10" placeholder="Enter your message" name="message"></textarea>
        <br><br>
        <button>Send</button>
    </form>
    
</body>
</html>